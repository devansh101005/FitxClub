# Copy this file to .env.local for local overrides, or set these in your hosting
# platform (Vercel: Project Settings → Environment Variables).
#
# Leave VITE_API_URL EMPTY in local dev — Vite proxies /api → http://localhost:8080.
# In production, set it to the full origin of your deployed backend.
#
# Example production value:
# VITE_API_URL=https://fitness-club-backend.onrender.com

VITE_API_URL=
